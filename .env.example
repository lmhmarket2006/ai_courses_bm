# ═════════════════════════════════════════════════════════════════════════
#  متغيّرات بيئة المشروع — انسخ هذا الملف إلى .env.local وعبّئ القيم الفعلية
#  Project Environment Variables — copy to .env.local and fill real values
# ═════════════════════════════════════════════════════════════════════════

# ─── ١) Gemini AI ────────────────────────────────────────────────────────
#
# ⚠️  أمان: لا تستخدم البادئة NEXT_PUBLIC_ أبداً مع المفاتيح السرية، لأنها
#     ستُحقَن في الحزمة وتُكشَف لكل زائر. هذا المفتاح يُقرَأ في server-side فقط
#     داخل /api/chat/route.ts.
#
# للحصول على مفتاح: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="ضع_مفتاحك_هنا"

# اختياري: تخصيص اسم الموديل بدون تعديل الكود.
# Examples: gemini-2.5-flash | gemini-2.5-pro | gemini-1.5-flash
# GEMINI_MODEL="gemini-2.5-flash"


# ─── ٢) عنوان الموقع (للـ SEO و CSRF) ───────────────────────────────────
#
# يُستخدم في:
#   • Open Graph & Twitter Cards (مشاركات السوشيال).
#   • Sitemap & canonical URLs.
#   • CSRF check: فحص أن طلبات API تأتي من نفس الـ origin.
#
# في dev اتركها http://localhost:3000
# في prod اجعلها رابط موقعك الفعلي (مثلاً: https://baytalmosawer.com)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"


# ─── ٣) Upstash Redis (Rate Limiting الإنتاجي) ──────────────────────────
#
# مطلوبتان لتشغيل /api/chat. تُستخدمان من lib/rate-limit.ts لتطبيق الحدود:
#   • burst: ١٠ طلب / ١٠ ثوانٍ  (يصدّ التفجير)
#   • minute: ٢٠ طلب / دقيقة     (الاستخدام الكثيف)
#   • hour: ١٠٠ طلب / ساعة       (سقف الحماية)
#
# الحصول على القيمتين:
#   ١. سجّل في https://console.upstash.com (مجاني — ١٠ آلاف طلب/يوم).
#   ٢. أنشئ Database من نوع Redis (اختر region أقرب لجمهورك).
#   ٣. افتح الـ Database → تبويب "REST API" → انسخ القيمتين أدناه.
#
# مثال لشكل القيم:
#   UPSTASH_REDIS_REST_URL="https://eternal-mongoose-12345.upstash.io"
#   UPSTASH_REDIS_REST_TOKEN="AYx...long-token..."
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""


# ─── ٤) اختياري: Google Analytics 4 ─────────────────────────────────────
#
# مفتاح GA4 إذا أردت تتبّع الزيارات.
# Optional: Google Analytics 4 measurement ID.
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
